rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Leaderboard: read-only for clients
    // Writes are only allowed via Cloud Functions (Admin SDK bypasses rules)
    match /leaderboard/{entry} {
      allow read: if true;
      allow write: if false; // Only Cloud Functions can write via Admin SDK
    }
    
    // Game sessions: no direct client access
    // All session management handled by Cloud Functions
    match /gameSessions/{session} {
      allow read, write: if false; // Only Cloud Functions can access
    }

    // Season pass reward definitions: clients can read, seed/admin tools write
    match /seasonConfigs/{seasonId} {
      allow read: if true;
      allow write: if false; // Only Admin SDK seed scripts can write
    }
    
    // Allow read access to levels
    match /levels/{level} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Users collection: allow read/write access
    // Note: This is a simple username/password system without Firebase Auth
    // In production, consider using Firebase Authentication for better security
    match /users/{username} {
      // Allow anyone to read (needed for login)
      allow read: if true;
      // Allow anyone to create (needed for registration)
      allow create: if true;
      // Allow anyone to update (needed for stats/purchases)
      // In a more secure setup, you'd validate the user somehow
      allow update: if true;
      // Don't allow deletes
      allow delete: if false;
    }

    // Admin-broadcasted game events (taco rain, meteor shower, etc).
    // Reads are public so every player can subscribe; writes are gated by
    // the admin UI today (Cloud Function hardening is a future task).
    match /events/{eventId} {
      allow read: if true;
      allow write: if true;
    }

    // Admin-broadcasted messages shown as a one-time top toast.
    match /messages/{messageId} {
      allow read: if true;
      allow write: if true;
    }

    // Global polls + per-user answer subdocs.
    match /polls/{pollId} {
      allow read: if true;
      allow write: if true;

      match /answers/{username} {
        allow read: if true;
        allow write: if true;
      }
    }
  }
}

