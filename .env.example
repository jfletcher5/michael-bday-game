# Copy to .env.local for local development.
# In CI, add these as GitHub Actions repository secrets instead.

# --- Firebase web app config (required for build + runtime) ---
# Firebase Console → Project Settings → Your apps → Web app config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=michaels-web-game
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional: point the client at a local Firestore emulator (dev only)
# NEXT_PUBLIC_FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# --- Deploy credentials (CI — use ONE of the two below) ---
# Option A: CI token from `npx firebase-tools login:ci`
# FIREBASE_TOKEN=

# Option B: Full service account JSON (needs Firebase Admin / deploy roles)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# --- Admin scripts (seed:seasons, reset:may-season) ---
# FIREBASE_PROJECT_ID=michaels-web-game
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# --- Cloud Functions anti-cheat secret (set in Firebase, not in client build) ---
# FUNCTIONS_SECRET_KEY=
